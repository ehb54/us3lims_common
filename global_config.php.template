## SSH-Slurm cluster config keys:
##
##   Required:
##     name       string  SSH hostname (used as login target if 'login' not set)
##     login      string  SSH login target, e.g. user@host (overrides name)
##     workdir    string  base path on submithost; job subdirectory appended at runtime
##     sshport    int     SSH port (normally 22)
##     queue      string  Slurm partition name
##     maxtime    int     maximum walltime in minutes (0 = unlimited when usemaxtime set)
##     ppn        int     procs per node
##     ppbj       int     procs per base job
##     maxproc    int     maximum total procs
##
##   Environment:
##     env_script_lines  string  verbatim shell preamble written into the Slurm script
##                               before the MPI launch line; include module commands,
##                               PATH/LD_LIBRARY_PATH exports, etc.
##
##   MPI launcher:
##     mpi_launcher  string  'mpirun' (default) | 'srun' | 'ibrun'
##                           mpirun: standard OpenMPI, used for most clusters
##                           srun:   Slurm-native; use for Anvil, Expanse
##                           ibrun:  TACC wrapper; required for Lonestar6, Stampede2
##
##   Optional scheduler/resource keys:
##     single_node   bool  collapse all ranks onto one node (e.g. USiaB)
##     usemaxtime    bool  use maxtime directly instead of computed estimate;
##                         set maxtime=0 for unlimited (emits 00:00:00 to Slurm)
##     wall_override int   fixed walltime in minutes (overrides computed; ignored if usemaxtime)
##     min_ppn       int   minimum procs per node floor
##     mempercore    int   MB per core (#SBATCH --mem-per-cpu)
##     pmg           bool  parallel Monte Carlo group support enabled
##     pmgonly       bool  cluster accepts PMG jobs only
##     submit_retries    int  override $global_sbatch_submit_retries for this cluster
##     submit_retry_wait int  override $global_sbatch_submit_retry_wait_seconds for this cluster

